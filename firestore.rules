// firestore.rules — Multi-tenant KyoriaOS
// Deploy: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Auth helpers ──────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'superadmin';
    }

    function isTenantOwner(tenantId) {
      return isSignedIn()
        && request.auth.token.role == 'owner'
        && request.auth.token.tenantId == tenantId;
    }

    function isTenantAdmin(tenantId) {
      return isSignedIn()
        && (request.auth.token.role == 'owner' || request.auth.token.role == 'admin')
        && request.auth.token.tenantId == tenantId;
    }

    function isTenantMember(tenantId) {
      return isSignedIn()
        && request.auth.token.tenantId == tenantId;
    }

    // ── Platform-level collections ────────────────────────────────────────────

    // Tenants: owners can read/update their own; superadmin full access
    match /tenants/{tenantId} {
      allow read:   if isTenantOwner(tenantId) || isSuperAdmin();
      allow create: if isSuperAdmin(); // created server-side via Admin SDK
      allow update: if isTenantOwner(tenantId) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      // ── Tenant sub-collections ──────────────────────────────────────────

      // Bookings: all writes go through authenticated API routes (Admin SDK bypasses rules)
      // No direct client writes allowed.
      match /bookings/{bookingId} {
        allow create: if false;
        allow read:   if isTenantMember(tenantId) || isSuperAdmin();
        allow update: if isTenantMember(tenantId) || isSuperAdmin();
        allow delete: if isTenantOwner(tenantId) || isSuperAdmin();
      }

      // Galleries: only tenant members and superadmin — galleries contain PII and delivery links
      match /galleries/{galleryId} {
        allow read:  if isTenantMember(tenantId) || isSuperAdmin();
        allow write: if isTenantMember(tenantId) || isSuperAdmin();
      }

      // Photographers (team members)
      match /photographers/{photographerId} {
        allow read, write: if isTenantMember(tenantId) || isSuperAdmin();
      }

      // Catalog: public read so booking form can load; tenant owner write
      match /packages/{id} {
        allow read:  if true;
        allow write: if isTenantOwner(tenantId) || isSuperAdmin();
      }
      match /services/{id} {
        allow read:  if true;
        allow write: if isTenantOwner(tenantId) || isSuperAdmin();
      }
      match /addons/{id} {
        allow read:  if true;
        allow write: if isTenantOwner(tenantId) || isSuperAdmin();
      }
    }

    // Rate limit docs — server-side only, no client access
    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    // Staff invite tokens — server-side only
    match /staffInviteTokens/{tokenId} {
      allow read, write: if false;
    }
  }
}
