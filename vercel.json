{
  "buildCommand": "next build",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "app/api/**": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/shoot-reminders",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/gallery-deliveries",
      "schedule": "*/15 * * * *"
    }
  ]
}
