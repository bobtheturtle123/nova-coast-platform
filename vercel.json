{
  "buildCommand": "next build",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "app/api/**": {
      "maxDuration": 30
    },
    "app/api/gallery/download-zip/route.js": {
      "maxDuration": 300
    },
    "app/api/cron/shoot-reminders/route.js": {
      "maxDuration": 300
    },
    "app/api/cron/gallery-deliveries/route.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/shoot-reminders",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/gallery-deliveries",
      "schedule": "0 8 * * *"
    }
  ]
}
