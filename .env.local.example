# ─────────────────────────────────────────────────────────────────────────────
# KyoriaOS — Multi-Tenant SaaS Environment Variables
# Copy this file to .env.local and fill in all values before running.
# NEVER commit .env.local to GitHub.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.kyoriaos.com   # Your production domain (or Vercel URL)

# ── Firebase (client-side) ────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase (server-side Admin SDK) ─────────────────────────────────────────
# Paste the entire service account JSON as a single line (minify it first)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Stripe (Platform Subscriptions + Connect) ────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Subscription price IDs — create these products in the Stripe dashboard first
# Starter: $49/mo  |  Professional: $99/mo  |  Agency: $199/mo
STRIPE_PRICE_STARTER=price_1TKCIL8qTZhsQAKqnowoAhBf
STRIPE_PRICE_PRO=price_1TKCJN8qTZhsQAKqnFkEKiNg
STRIPE_PRICE_AGENCY=price_1TKCJu8qTZhsQAKqRx4PyjmM

# Platform fee taken per booking (basis points: 150 = 1.5%)
PLATFORM_FEE_BPS=150

# ── Cloudflare R2 (Media Storage) ────────────────────────────────────────────
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=kyoriaos-media
NEXT_PUBLIC_R2_PUBLIC_URL=https://media.kyoriaos.com

# ── Mapbox (Service Area Map Drawing) ────────────────────────────────────────
# Client-side token: exposed in browser, used by mapbox-gl for service area drawing
# IMPORTANT: Restrict this token to https://app.kyoriaos.com in the Mapbox dashboard
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...
# Server-side token: used in API routes (geocoding fallback, service area checks)
# Should be a SECRET token (not public) — restrict to server IPs if possible
MAPBOX_TOKEN=sk.eyJ1...

# ── LocationIQ (Primary Geocoding + Autocomplete) ────────────────────────────
# Primary address autocomplete and geocoding. Free tier: 10,000 requests/day.
# Get a key at https://locationiq.com — set server-side only for security
LOCATIONIQ_KEY=
# Public fallback (for client-side components that need geocoding directly)
NEXT_PUBLIC_LOCATIONIQ_KEY=

# ── AI Providers ─────────────────────────────────────────────────────────────
# Primary: DeepSeek (cheapest — $0.14/1M input tokens)
# Fallback: OpenAI gpt-4o-mini ($0.15/1M input tokens)
# At least one must be set to enable: AI chat, captions, product import, property chat
DEEPSEEK_API_KEY=sk-...
OPENAI_API_KEY=sk-...

# ── Twilio (SMS Notifications) ────────────────────────────────────────────────
# Required for SMS on Studio/Pro/Scale plans
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1...

# ── Cron Job Security ─────────────────────────────────────────────────────────
# Random secret that Vercel passes when calling cron endpoints
# Generate with: openssl rand -base64 32
CRON_SECRET=change_me

# ── Sentry (Error Monitoring) ─────────────────────────────────────────────────
# Get DSN from https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=https://...@o123456.ingest.sentry.io/123456
NEXT_PUBLIC_SENTRY_DSN=https://...@o123456.ingest.sentry.io/123456
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=kyoriaos
SENTRY_AUTH_TOKEN=sntrys_...

# ── Resend (Email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
# CRITICAL: Must match the verified sending domain in Resend → Domains.
# Verified domain = mail.kyoriaos.com → use noreply@mail.kyoriaos.com
# If you verified a different subdomain, use that. @kyoriaos.com is NOT verified.
RESEND_FROM_EMAIL=noreply@mail.kyoriaos.com

# ── Superadmin ────────────────────────────────────────────────────────────────
# Email of the platform owner — run scripts/set-superadmin.js after first deploy
SUPERADMIN_EMAIL=you@yourcompany.com

# ── Admin API ────────────────────────────────────────────────────────────────
# Secret for /api/admin/* endpoints (plan upgrades, etc.)
# Generate with: openssl rand -base64 32
ADMIN_SECRET=change_me_in_production
