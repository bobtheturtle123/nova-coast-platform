# ─────────────────────────────────────────────────────────────────────────────
# ShootFlow — Multi-Tenant SaaS Environment Variables
# Copy this file to .env.local and fill in all values before running.
# NEVER commit .env.local to GitHub.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.shootflow.com   # Your production domain (or Vercel URL)

# ── Firebase (client-side) ────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase (server-side Admin SDK) ─────────────────────────────────────────
# Paste the entire service account JSON as a single line (minify it first)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Stripe (Platform Subscriptions + Connect) ────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Subscription price IDs — create these products in the Stripe dashboard first
# Starter: $49/mo  |  Professional: $99/mo  |  Agency: $199/mo
STRIPE_PRICE_STARTER=price_1TKCIL8qTZhsQAKqnowoAhBf
STRIPE_PRICE_PRO=price_1TKCJN8qTZhsQAKqnFkEKiNg
STRIPE_PRICE_AGENCY=price_1TKCJu8qTZhsQAKqRx4PyjmM

# Platform fee taken per booking (basis points: 150 = 1.5%)
PLATFORM_FEE_BPS=150

# ── Cloudflare R2 (Media Storage) ────────────────────────────────────────────
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=shootflow-media
NEXT_PUBLIC_R2_PUBLIC_URL=https://media.shootflow.com

# ── Google Maps ──────────────────────────────────────────────────────────────
# Server-side: used for travel fee distance calculations
GOOGLE_MAPS_API_KEY=
# Client-side: used for address autocomplete (booking form) and map drawing (service areas)
# Same key as above — add BOTH to Vercel if using these features
# Ensure "Maps JavaScript API" and "Places API" are enabled in your Google Cloud project
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ── Resend (Email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Superadmin ────────────────────────────────────────────────────────────────
# Email of the platform owner — run scripts/set-superadmin.js after first deploy
SUPERADMIN_EMAIL=you@yourcompany.com
